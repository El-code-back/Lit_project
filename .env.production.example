# === ПРОДАКШЕН ===
# Сгенерируйте надежный ключ: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-production-secret-key

DEBUG=False

# Домены через запятую
ALLOWED_HOSTS=.onrender.com,localhost,127.0.0.1,your-custom-domain.com

# Для CSRF (обязательно указывать протокол)
CSRF_TRUSTED_ORIGINS=https://lit-project.onrender.com,http://localhost:8000,http://127.0.0.1:8000

# Постоянная база на проде. Для Vercel лучше подключить Postgres и вставить DATABASE_URL.
# DATABASE_URL=postgresql://user:password@host:5432/database

# Стартовые уроки создаются как обычные записи в пустой базе.
SEED_SAMPLE_LESSONS=True

# Видеофайлы и файлы заданий на Vercel нужно хранить во внешнем S3/R2-compatible storage.
USE_S3=False
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=
# AWS_S3_ENDPOINT_URL=
# AWS_S3_CUSTOM_DOMAIN=
