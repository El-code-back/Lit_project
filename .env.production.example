# === ПРОДАКШЕН ===
# Сгенерируйте надежный ключ: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-production-secret-key

DEBUG=False

# Домены через запятую
ALLOWED_HOSTS=.onrender.com,localhost,127.0.0.1,your-custom-domain.com

# Для CSRF (обязательно указывать протокол)
CSRF_TRUSTED_ORIGINS=https://lit-project.onrender.com,http://localhost:8000,http://127.0.0.1:8000
